### X:
TWITTER_VERSION=11.81.0-release.0
# TWITTER_OLD_KEY=True
# TWITTER_KEYSTORE_FILE_NAME=revanced.keystore
# TWITTER_ARCHS_TO_BUILD=arm64-v8a
