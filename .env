### Global:
# DRY_RUN=False
# GLOBAL_OLD_KEY=True
# GLOBAL_KEYSTORE_FILE_NAME=revanced.keystore
GLOBAL_ARCHS_TO_BUILD=arm64-v8a
# GLOBAL_SPACE_FORMATTED_PATCHES=True
# GLOBAL_CLI_ARGSF=revanced-cli-v6
# GLOBAL_CLI_DL=https://github.com/revanced/revanced-cli/releases/latest
# GLOBAL_PATCHES_DL=https://github.com/revanced/revanced-patches/releases/latest
PATCH_APPS=youtube,youtube_music,reddit,sync,trakt,twitter,instagram
EXTRA_FILES=https://github.com/MorpheApp/MicroG-RE/releases/latest@MicroG-RE.apk
# EXISTING_DOWNLOADED_APKS=
REPACK_SPLIT_APKS=True

### YouTube:
# YOUTUBE_VERSION=latest_supported
# YOUTUBE_OLD_KEY=True
# YOUTUBE_KEYSTORE_FILE_NAME=revanced.keystore
# YOUTUBE_ARCHS_TO_BUILD=arm64-v8a
YOUTUBE_CLI_ARGSF=morphe-cli
YOUTUBE_CLI_DL=https://github.com/MorpheApp/morphe-cli/releases/latest
YOUTUBE_PATCHES_DL=https://github.com/MorpheApp/morphe-patches/releases/latest
# YOUTUBE_SPACE_FORMATTED_PATCHES=True
YOUTUBE_INCLUDE_PATCH=change-package-name,disable-play-store-updates
YOUTUBE_EXCLUDE_PATCH=materialyou,change-header
YOUTUBE_OPTIONS_RAW="
Custom branding:
  App name: YouTube
  Custom icon: resources/youtube/branding/mmt
"

### YouTube Music:
# YOUTUBE_MUSIC_VERSION=latest_supported
# YOUTUBE_MUSIC_OLD_KEY=True
# YOUTUBE_MUSIC_KEYSTORE_FILE_NAME=revanced.keystore
# YOUTUBE_MUSIC_ARCHS_TO_BUILD=arm64-v8a
YOUTUBE_MUSIC_CLI_ARGSF=morphe-cli
YOUTUBE_MUSIC_CLI_DL=https://github.com/MorpheApp/morphe-cli/releases/latest
YOUTUBE_MUSIC_PATCHES_DL=https://github.com/MorpheApp/morphe-patches/releases/latest
# YOUTUBE_MUSIC_SPACE_FORMATTED_PATCHES=True
YOUTUBE_MUSIC_INCLUDE_PATCH=change-package-name,disable-play-store-updates
# YOUTUBE_MUSIC_EXCLUDE_PATCH=
YOUTUBE_MUSIC_OPTIONS_RAW="
Custom branding:
  App name: YT Music
  Custom icon: resources/youtube_music/branding/mmt
"

