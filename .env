TWITTER_CLI_DL=https://github.com/MorpheApp/morphe-cli/releases/latest
TWITTER_PATCHES_DL=https://github.com/crimera/piko/releases/latest-prerelease
# TWITTER_SPACE_FORMATTED_PATCHES=True
# TWITTER_INCLUDE_PATCH=
